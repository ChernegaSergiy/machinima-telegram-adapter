{
    "name": "morfeditorial/machinima-telegram-adapter",
    "description": "Telegram platform adapter for the Machinima core app.",
    "type": "symfony-bundle",
    "license": "LicenseRef-CSSM-Unlimited-2.0",
    "authors": [
        {
            "name": "Serhii Cherneha",
            "email": "chernegasergiy3@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "lcobucci/jwt": "^5.6",
        "morfeditorial/machinima-core": "dev-main",
        "morfeditorial/telegram-bot-bundle": "dev-main",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/notifier": "8.1.*",
        "symfony/telegram-notifier": "8.1.*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "Morfeditorial\\MachinimaTelegramAdapter\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
