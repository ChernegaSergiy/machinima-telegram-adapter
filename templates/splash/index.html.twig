<style>
  /* ============================================================
     MORF · SPLASH SCREEN v3 — стисла, але така ж витончена
     ============================================================ */
  :root {
    --ink: #14161c;
    --soft: rgba(20, 22, 28, 0.55);
    --bg1: #f0f4fa;
    --bg2: #e6edf5;
  }

  #morf-splash {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100dvh;
    background: linear-gradient(145deg, var(--bg1), var(--bg2));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    transition: opacity .6s cubic-bezier(.22, 1, .36, 1), visibility .6s cubic-bezier(.22, 1, .36, 1);
    z-index: 9999;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  #morf-splash.morf-hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* — фон: орби + шум — */
  .morf-bg {
    position: absolute;
    inset: -20%;
    filter: blur(70px);
    opacity: .5;
    pointer-events: none;
  }
  .morf-bg>div {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }
  .morf-bg>div:nth-child(1) {
    width: 70vmax;
    height: 70vmax;
    left: -20%;
    top: -30%;
    background: radial-gradient(circle at 30% 40%, #b9d8f2 0%, rgba(185, 216, 242, 0) 72%);
    animation: f1 18s ease-in-out infinite alternate;
  }
  .morf-bg>div:nth-child(2) {
    width: 60vmax;
    height: 60vmax;
    right: -15%;
    bottom: -25%;
    background: radial-gradient(circle at 70% 60%, #c5e8d1 0%, rgba(197, 232, 209, 0) 70%);
    animation: f2 22s ease-in-out infinite alternate;
  }
  .morf-bg>div:nth-child(3) {
    width: 50vmax;
    height: 50vmax;
    left: 10%;
    bottom: -10%;
    background: radial-gradient(circle at 60% 30%, #f0e6c8 0%, rgba(240, 230, 200, 0) 74%);
    animation: f3 20s ease-in-out infinite alternate;
  }
  @keyframes f1 { 100% { transform: translate(8%, -6%) scale(1.12) } }
  @keyframes f2 { 100% { transform: translate(-7%, 8%) scale(1.08) } }
  @keyframes f3 { 100% { transform: translate(5%, 5%) scale(1.06) } }

  .morf-grain {
    position: absolute;
    inset: 0;
    opacity: .04;
    pointer-events: none;
    mix-blend-mode: overlay;
    width: 100%;
    height: 100%;
  }

  /* — контент — */
  .morf-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px;
    gap: 32px;
    text-align: center;
  }

  /* — логотип (вхід + дихання) — */
  .morf-logo {
    width: min(60vmin, 240px);
    height: min(60vmin, 240px);
    opacity: 0;
    transform: translateY(20px) scale(.92);
    animation: logoIn .8s cubic-bezier(.16, 1, .3, 1) .1s both;
  }
  .morf-logo svg {
    display: block;
    width: 100%;
    height: 100%;
    animation: breathe 4s ease-in-out .9s infinite;
  }
  .morf-logo svg path {
    fill: var(--ink);
  }
  @keyframes logoIn { 100% { opacity: 1; transform: translateY(0) scale(1) } }
  @keyframes breathe { 50% { transform: scale(1.02) } }

  /* — текст + бейдж — */
  .morf-label {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: .02em;
    color: var(--soft);
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp .6s cubic-bezier(.16, 1, .3, 1) .5s both;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .morf-label .at {
    font-weight: 300;
    opacity: .5;
  }
  .morf-label .badge {
    color: #3b7cff;
    font-weight: 600;
    background: rgba(59, 124, 255, .08);
    padding: 2px 10px 2px 8px;
    border-radius: 40px;
  }

  /* — три крапки — */
  .morf-dots {
    display: flex;
    gap: 12px;
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp .6s cubic-bezier(.16, 1, .3, 1) .65s both;
  }
  .morf-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink);
    opacity: .2;
    animation: dot 1.4s ease-in-out infinite;
  }
  .morf-dot:nth-child(2) { animation-delay: .2s }
  .morf-dot:nth-child(3) { animation-delay: .4s }
  @keyframes dot { 50% { opacity: 1; transform: translateY(-4px) scale(1.2) } }
  @keyframes fadeUp { 100% { opacity: 1; transform: translateY(0) } }

  /* — зменшений рух — */
  @media(prefers-reduced-motion:reduce) {
    .morf-bg>div, .morf-logo, .morf-logo svg, .morf-label, .morf-dots, .morf-dot {
      animation: none !important;
    }
    .morf-logo { opacity: 1; transform: none; }
    .morf-label, .morf-dots { opacity: 1; transform: none; }
    .morf-dot { opacity: .5; }
  }

  /* — адаптив — */
  @media(max-width:480px) {
    .morf-logo { width: min(50vmin, 180px); height: min(50vmin, 180px); }
    .morf-label { font-size: 13px; }
    .morf-dots { gap: 10px; }
  }
</style>

<div id="morf-splash">
  <!-- фон: орби + шум -->
  <div class="morf-bg" aria-hidden="true">
    <div></div><div></div><div></div>
  </div>
  <svg class="morf-grain" width="100%" height="100%" aria-hidden="true">
    <filter id="n">
      <feTurbulence type="fractalNoise" baseFrequency=".75" numOctaves="2" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#n)" />
  </svg>

  <div class="morf-content">
    <!-- логотип -->
    <div class="morf-logo">
      {{ include('@MachinimaTelegramAdapter/splash/logo.html.twig') }}
    </div>

    <div class="morf-label">
      <span class="at">@</span>machinima_bot
      <span class="badge">✦ beta</span>
    </div>

    <div class="morf-dots" aria-hidden="true">
      <div class="morf-dot"></div>
      <div class="morf-dot"></div>
      <div class="morf-dot"></div>
    </div>
  </div>
</div>
